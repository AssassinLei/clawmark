<view class="container">
  <view class="card">
    <view class="title">相册列表</view>
    <picker mode="selector" range="{{typeOptions}}" value="{{typeIndex}}" bindchange="onTypeChange">
      <view class="subtle">筛选类型：{{typeOptions[typeIndex]}}</view>
    </picker>
    <view class="row-between mt10">
      <view class="subtle">总数：{{total}}</view>
      <button size="mini" type="primary" bindtap="onCreateAlbum" loading="{{creating}}">新建相册</button>
    </view>

    <view wx:if="{{showCreateForm}}" class="create-form mt10">
      <input class="form-input" placeholder="请输入相册名称（1-30字）" value="{{draftTitle}}" bindinput="onDraftTitleInput" />
      <input class="form-input mt10" placeholder="请输入城市名（如 北京市）" value="{{draftCityName}}" bindinput="onDraftCityInput" />
      <view class="row-end mt10">
        <button size="mini" bindtap="onCancelCreateAlbum">取消</button>
        <button size="mini" type="primary" loading="{{creating}}" bindtap="onConfirmCreateAlbum">确认创建</button>
      </view>
    </view>
  </view>


  <view wx:if="{{error}}" class="card mt20">
    <text class="subtle">{{error}}</text>
  </view>

  <view wx:if="{{!loading && albums.length===0}}" class="card mt20">
    <text class="subtle">暂无相册数据。</text>
  </view>

  <view wx:for="{{albums}}" wx:key="album_id" class="card mt20 clickable album-card" bindtap="onTapAlbum" data-id="{{item.album_id}}" data-title="{{item.title}}" data-type="{{item.type}}" data-citycode="{{item.city_code}}">
    <view class="row-between">
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="subtle">城市：{{item.city_name || item.city_code || '未设置'}}</view>
        <view class="subtle">创建时间：{{item.created_at_text || '--'}}</view>
      </view>
      <view class="count">{{item.photo_count}} 张</view>
    </view>
    <view class="subtle mt10">点击查看并上传照片</view>
      <button
        class="danger-mini corner-delete"
        size="mini"
        type="default"
        plain="true"
        loading="{{deletingAlbumId===item.album_id}}"
        data-id="{{item.album_id}}"
        catchtap="onDeleteAlbum"
      >删除相册</button>
  </view>

  <view wx:if="{{loadingMore}}" class="loading-more">加载中...</view>
  <view wx:if="{{!loading && !hasMore && albums.length>0}}" class="loading-more subtle">没有更多了</view>
</view>
