.container { padding: 24rpx; }
.mt16 { margin-top: 16rpx; }
.filter-row { display:flex; gap: 10rpx; margin-top: 12rpx; align-items:center; }
.upload-row { display:flex; align-items:center; gap: 14rpx; margin-top: 6rpx; }
.upload-title { margin-bottom: 10rpx; }
.field-label { font-size: 24rpx; color: #4e5969; }
.date-picker {
  background: #f2f3f5;
  border: 1rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}
.year-input {
  flex: 1;
  background: #f2f3f5;
  border: 1rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}
.thumb {
  width: 100%;
  height: 320rpx;
  border-radius: 14rpx;
  background: #f2f3f5;
}
.selected-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}
.selected-thumb {
  width: 100%;
  height: 180rpx;
  border-radius: 10rpx;
  background: #f2f3f5;
}
.photo-card {
  position: relative;
  padding-right: 132rpx;
  padding-bottom: 56rpx;
}
.photo-meta { margin-top: 12rpx; }
.danger-mini {
  height: 36rpx;
  line-height: 32rpx;
  padding: 0 10rpx;
  font-size: 16rpx;
  min-width: 92rpx;
  color: #6b7280 !important;
  border-color: #d1d5db !important;
  background: #f9fafb !important;
}
.corner-delete {
  position: absolute;
  right: 16rpx;
  bottom: 14rpx;
}
.photo-title { font-size: 30rpx; font-weight: 600; }
.loading-more { text-align: center; padding: 22rpx 0; color: #86909c; }


