<view class="container">
  <view class="card">
    <view class="title">{{provinceName}}相册</view>
    <view class="subtle">共 {{total}} 本城市相册</view>
  </view>

  <view wx:if="{{error}}" class="card mt16">
    <text class="subtle">{{error}}</text>
  </view>

  <view wx:if="{{!loading && albums.length===0}}" class="card mt16">
    <text class="subtle">该省份暂无相册。</text>
  </view>

  <view wx:for="{{albums}}" wx:key="album_id" class="card mt16 clickable" bindtap="onTapAlbum" data-id="{{item.album_id}}" data-title="{{item.title}}" data-citycode="{{item.city_code}}">
    <view class="row-between">
      <view>
        <view class="album-title">{{item.title}}</view>
        <view class="subtle">{{item.city_code}} · {{item.created_at}}</view>
      </view>
      <view class="count">{{item.photo_count}} 张</view>
    </view>
    <view class="subtle mt8">点击查看该相册全部照片</view>
  </view>
</view>
