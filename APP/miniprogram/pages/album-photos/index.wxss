.container { padding: 24rpx; }
.mt16 { margin-top: 16rpx; }
.filter-row { display:flex; gap: 10rpx; margin-top: 12rpx; align-items:center; }
.year-input {
  flex: 1;
  background: #f2f3f5;
  border: 1rpx solid #e5e6eb;
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
}
.thumb {
  width: 100%;
  height: 320rpx;
  border-radius: 14rpx;
  background: #f2f3f5;
}
.photo-meta { margin-top: 12rpx; }
.photo-title { font-size: 30rpx; font-weight: 600; }
.loading-more { text-align: center; padding: 22rpx 0; color: #86909c; }
